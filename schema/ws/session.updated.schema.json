{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatepilot.local/schema/ws/session.updated.schema.json",
  "title": "session.updated",
  "allOf": [
    { "$ref": "envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "session.updated" },
        "payload": {
          "type": "object",
          "required": ["tenant_id", "session_id", "device_id", "status", "pending_approval_count", "last_output_summary"],
          "properties": {
            "tenant_id": { "type": "string" },
            "session_id": { "type": "string" },
            "device_id": { "type": "string" },
            "status": {
              "enum": ["starting", "running", "waiting_approval", "completed", "failed", "closed", "lost"]
            },
            "pending_approval_count": { "type": "integer", "minimum": 0 },
            "last_output_summary": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
