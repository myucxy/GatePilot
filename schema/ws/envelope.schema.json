{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatepilot.local/schema/ws/envelope.schema.json",
  "title": "GatePilot WebSocket Envelope",
  "type": "object",
  "required": ["type", "message_id", "trace_id", "sent_at", "schema_version", "payload"],
  "properties": {
    "type": { "type": "string", "minLength": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "sent_at": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string", "const": "2026-04-01" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
